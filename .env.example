# ====================================================
# ConstructOS Environment Configuration
# Copy this file to '.env' and fill in correct values.
# ====================================================

# Node Runtime
NODE_ENV=development
PORT=3001

# PostgreSQL Database Connection
# Replace user, password, host, port, and dbname as appropriate for your setup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/constructos?schema=public"

# Authentication Config
# Use a highly-secure random string for production environments.
JWT_SECRET="constructos_super_secure_jwt_signing_secret_key_2026"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="constructos_super_secure_jwt_refresh_signing_secret_key_2026"
JWT_REFRESH_EXPIRES_IN="7d"

# Client Web Settings
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# Maintenance Mode
NEXT_PUBLIC_MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_SECRET=construct2026
