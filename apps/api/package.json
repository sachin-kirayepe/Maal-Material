{
  "name": "@constructos/api",
  "version": "1.0.0",
  "private": true,
  "description": "Maal-Material Industrial Commerce API built with NestJS and Prisma ORM",
  "author": "Maal-Material Architecture Team",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build -b swc",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node --max-old-space-size=8192 node_modules/@nestjs/cli/bin/nest.js start",
    "dev": "node --max-old-space-size=8192 node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node --max-old-space-size=8192 node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node --max-old-space-size=8192 dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest --runInBand --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --passWithNoTests"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@constructos/types$": "<rootDir>/../../../packages/types/src",
      "^@constructos/utils$": "<rootDir>/../../../packages/utils/src"
    }
  },
  "dependencies": {
    "@constructos/types": "workspace:*",
    "@constructos/utils": "workspace:*",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.13.0",
    "@sentry/nestjs": "^10.57.0",
    "@sentry/node": "^10.57.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "groq-sdk": "^1.2.1",
    "ioredis": "^5.11.0",
    "joi": "^17.13.1",
    "json-rules-engine": "^7.3.1",
    "nestjs-i18n": "^10.8.4",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cron": "^2.4.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.13.0",
    "prisma-case-format": "^2.2.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
