model SLADefinition {
  id              String   @id @default(uuid())
  tenantId        String
  name            String   // e.g. "RFQ Response SLA", "Delivery Fulfillment SLA"
  module          String   // PROCUREMENT, LOGISTICS, WORKFORCE, RENTAL, FINANCE
  triggerEvent    String   // e.g. "RFQ_CREATED", "ORDER_PLACED", "ATTENDANCE_UNMARKED"
  deadlineHours   Int      // Hours before SLA breach
  warningHours    Int?     // Hours before warning alert (optional early warning)
