// ==========================================
// OFFLINE-FIRST & RESILIENCE INFRASTRUCTURE
// ==========================================

model OfflineDevice {
  id            String                      @id @default(uuid())
  tenantId      String
  deviceName    String
  lastSyncAt    DateTime?
  networkStatus String                      @default("ONLINE")
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  queues        OfflineQueue[]
  checkpoints   SyncCheckpoint[]
  analytics     NetworkConditionAnalytics[]
  syncSessions  EdgeSyncSession[]

  @@index([tenantId])
}

model OfflineQueue {
  id           String   @id @default(uuid())
  deviceId     String
  tenantId     String
  operation    String // e.g., 'CREATE_INVOICE', 'UPDATE_STOCK'
  payload      String
  status       String   @default("PENDING") // PENDING, SYNCED, FAILED
  retryCount   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  device         OfflineDevice   @relation(fields: [deviceId], references: [id])
  syncOperations SyncOperation[]

  @@index([deviceId, status])
  @@index([tenantId])
}

model SyncOperation {
  id          String    @id @default(uuid())
  queueId     String
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, SUCCESS, CONFLICT
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  queue     OfflineQueue         @relation(fields: [queueId], references: [id])
  conflicts ConflictResolution[]

  @@index([queueId])
}

model ConflictResolution {
  id         String   @id @default(uuid())
  syncOpId   String
  entityType String // e.g., 'StockMovement', 'Invoice'
  entityId   String
  localData  String
  serverData String
  resolution String   @default("PENDING") // PENDING, SERVER_WINS, LOCAL_WINS, MERGED
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  syncOperation SyncOperation         @relation(fields: [syncOpId], references: [id])
  auditTrail    ReconciliationAudit[]

  @@index([syncOpId])
}

model ReconciliationAudit {
  id          String   @id @default(uuid())
  conflictId  String
  actionTaken String
  performedBy String
  timestamp   DateTime @default(now())
  notes       String?

  conflict ConflictResolution @relation(fields: [conflictId], references: [id])

  @@index([conflictId])
}

model SyncCheckpoint {
  id            String   @id @default(uuid())
  deviceId      String
  entityType    String
  lastWatermark DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  device OfflineDevice @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, entityType])
}

model DistributedOperation {
  id        String   @id @default(uuid())
  tenantId  String
  sagaId    String
  step      String
  status    String   @default("STARTED") // STARTED, COMPLETED, COMPENSATED
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, sagaId])
}

model OfflineSnapshot {
  id           String   @id @default(uuid())
  tenantId     String
  entityType   String
  snapshotData String
  version      Int      @default(1)
  createdAt    DateTime @default(now())

  @@index([tenantId, entityType])
}

model WhatsAppWorkflow {
  id             String   @id @default(uuid())
  tenantId       String
  shopId         String
  phoneNumber    String
  workflowType   String // QUOTATION, PAYMENT_REMINDER, ORDER_UPDATE
  status         String   @default("DRAFT") // DRAFT, SENT, DELIVERED, READ, REPLIED, COMPLETED
  contextPayload String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, phoneNumber])
}

model NetworkConditionAnalytics {
  id             String   @id @default(uuid())
  deviceId       String
  connectionType String // 4G, 3G, 2G, OFFLINE
  latencyMs      Int?
  packetLoss     Float?
  timestamp      DateTime @default(now())

  device OfflineDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, timestamp])
}

