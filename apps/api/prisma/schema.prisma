generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ApprovalWorkflow {
  id           String   @id @default(uuid())
  tenantId     String
  workflowType String
  referenceId  String
  step         Int      @default(1)
  totalSteps   Int
  status       String   @default("PENDING")
  requestedBy  String
  assignedRole String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("approval_workflows")
}

model BankAccount {
  id                   String                 @id @default(uuid())
  tenantId             String
  bankName             String
  accountNumber        String
  accountType          String
  currency             String                 @default("USD")
  currentBalance       Float                  @default(0)
  routingNumber        String?
  swiftCode            String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  reconciliationRecord ReconciliationRecord[]

  @@unique([tenantId, accountNumber])
  @@map("bank_accounts")
}

model ChartOfAccount {
  id                   String                 @id @default(uuid())
  tenantId             String
  code                 String
  name                 String
  type                 String
  category             String
  description          String?
  parentCode           String?
  isActive             Boolean                @default(true)
  isControl            Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  generalLedgerAccount GeneralLedgerAccount[]

  @@unique([tenantId, code])
  @@map("chart_of_accounts")
}

model ClusterNode {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  role       String
  ipAddress  String?
  region     String
  status     String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([tenantId, region])
  @@map("cluster_nodes")
}

model Deployment {
  id              String            @id @default(uuid())
  tenantId        String
  version         String
  environment     String
  status          String
  initiatorId     String?
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  logs            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deploymentEvent DeploymentEvent[]

  @@index([status])
  @@index([tenantId, environment])
  @@map("deployments")
}

model DeploymentEvent {
  id           String     @id @default(uuid())
  deploymentId String
  state        String
  message      String?
  timestamp    DateTime   @default(now())
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@map("deployment_events")
}

model EnvironmentConfig {
  id          String   @id @default(uuid())
  tenantId    String
  environment String
  key         String
  value       String
  isSecret    Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, environment, key])
  @@map("environment_configs")
}

model FinancialAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  entityType  String
  entityId    String
  action      String
  performedBy String
  ipAddress   String?
  oldValues   String?
  newValues   String?
  timestamp   DateTime @default(now())

  @@map("financial_audit_logs")
}

model FinancialTransaction {
  id                   String               @id @default(uuid())
  tenantId             String
  journalEntryId       String
  ledgerAccountId      String
  transactionDate      DateTime
  type                 String
  amount               Float
  currency             String               @default("USD")
  exchangeRate         Float                @default(1.0)
  description          String?
  status               String               @default("POSTED")
  createdAt            DateTime             @default(now())
  generalLedgerAccount GeneralLedgerAccount @relation(fields: [ledgerAccountId], references: [id])
  journalEntry         JournalEntry         @relation(fields: [journalEntryId], references: [id])

  @@index([tenantId, transactionDate])
  @@map("financial_transactions")
}

model GeneralLedgerAccount {
  id                   String                 @id @default(uuid())
  tenantId             String
  chartOfAccountId     String
  accountNumber        String
  name                 String
  balance              Float                  @default(0)
  currency             String                 @default("USD")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  financialTransaction FinancialTransaction[]
  chartOfAccount       ChartOfAccount         @relation(fields: [chartOfAccountId], references: [id])

  @@unique([tenantId, accountNumber])
  @@map("general_ledger_accounts")
}

model InfrastructureMetric {
  id         String   @id @default(uuid())
  tenantId   String
  nodeId     String
  metricType String
  value      Float
  unit       String
  timestamp  DateTime @default(now())

  @@index([nodeId, timestamp])
  @@index([tenantId, metricType])
  @@map("infrastructure_metrics")
}

model JournalEntry {
  id                   String                 @id @default(uuid())
  tenantId             String
  entryNumber          String
  referenceType        String
  referenceId          String?
  entryDate            DateTime
  description          String?
  status               String                 @default("DRAFT")
  postedBy             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  financialTransaction FinancialTransaction[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId, status, entryDate])
  @@map("journal_entries")
}

model PipelineExecution {
  id           String    @id @default(uuid())
  tenantId     String
  pipelineName String
  commitHash   String?
  branch       String?
  status       String
  durationMs   Int?
  triggeredBy  String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([status])
  @@index([tenantId, pipelineName])
  @@map("pipeline_executions")
}

model ReconciliationRecord {
  id               String      @id @default(uuid())
  tenantId         String
  bankAccountId    String
  periodStart      DateTime
  periodEnd        DateTime
  statementBalance Float
  systemBalance    Float
  difference       Float
  status           String      @default("PENDING")
  reconciledBy     String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("reconciliation_records")
}

model ReleaseVersion {
  id          String    @id @default(uuid())
  tenantId    String
  version     String
  notes       String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("release_versions")
}

model SecretReference {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  provider     String
  referenceKey String
  environment  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, environment, name])
  @@map("secret_references")
}

model TaxRecord {
  id            String    @id @default(uuid())
  tenantId      String
  taxRuleId     String
  referenceType String
  referenceId   String
  taxableAmount Float
  taxAmount     Float
  currency      String    @default("USD")
  status        String    @default("UNPAID")
  filedAt       DateTime?
  createdAt     DateTime  @default(now())
  taxRule       TaxRule   @relation(fields: [taxRuleId], references: [id])

  @@map("tax_records")
}

model TaxRule {
  id          String      @id @default(uuid())
  tenantId    String
  country     String
  region      String?
  taxType     String
  taxRate     Float
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  taxRecord   TaxRecord[]

  @@unique([tenantId, taxType, country, region])
  @@map("tax_rules")
}

model AccessPolicy {
  id         String   @id @default(uuid())
  tenantId   String?
  roleId     String?
  resource   String
  action     String
  effect     String   @default("ALLOW")
  conditions String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roles      Role?    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenants    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([resource])
  @@index([roleId])
  @@index([tenantId])
  @@map("access_policies")
}

model AccountStatement {
  id              String        @id @default(uuid())
  ledgerAccountId String
  statementPeriod String
  startDate       DateTime
  endDate         DateTime
  openingBalance  Float
  closingBalance  Float
  totalDebits     Float
  totalCredits    Float
  fileUrl         String?
  generatedAt     DateTime      @default(now())
  tenantId        String?
  tenants         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledgerAccounts  LedgerAccount @relation(fields: [ledgerAccountId], references: [id])

  @@index([statementPeriod])
  @@index([ledgerAccountId])
  @@map("account_statements")
}

model ActivityLog {
  id         String   @id @default(uuid())
  tenantId   String?
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenants    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User?    @relation(fields: [actorId], references: [id])

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([tenantId])
  @@map("activity_logs")
}

model AiActionLog {
  id          String   @id @default(uuid())
  tenantId    String?
  actionType  String
  description String
  payload     String?
  status      String   @default("SUCCESS")
  executedAt  DateTime @default(now())
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([actionType])
  @@index([tenantId])
  @@map("ai_action_logs")
}

model AiInsight {
  id          String   @id @default(uuid())
  tenantId    String?
  type        String
  title       String
  description String
  confidence  Float    @default(0.0)
  metrics     String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([type])
  @@index([tenantId])
  @@map("ai_insights")
}

model AnalyticsSnapshot {
  id           String   @id @default(uuid())
  tenantId     String?
  snapshotDate DateTime
  metrics      String
  module       String
  createdAt    DateTime @default(now())
  tenants      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, snapshotDate, module])
  @@index([module])
  @@index([tenantId])
  @@map("analytics_snapshots")
}

model AnomalyEvent {
  id          String    @id @default(uuid())
  tenantId    String?
  anomalyType String
  severity    String    @default("WARNING")
  description String
  evidence    String
  status      String    @default("DETECTED")
  detectedAt  DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  tenants     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([severity])
  @@index([anomalyType])
  @@index([tenantId])
  @@map("anomaly_events")
}

model AuditTrail {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String
  entityId   String
  oldData    String?
  newData    String?
  createdAt  DateTime @default(now())
  users      User?    @relation(fields: [userId], references: [id])
  tenants    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([tenantId])
  @@map("audit_trails")
}

model AutomationWorkflow {
  id                 String              @id @default(uuid())
  tenantId           String?
  name               String
  description        String?
  triggerType        String
  triggerData        String
  actions            String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenants            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowExecutions WorkflowExecution[]

  @@index([isActive])
  @@index([tenantId])
  @@map("automation_workflows")
}

model BackgroundJob {
  id         String    @id @default(uuid())
  jobName    String
  queueName  String
  jobId      String
  status     String    @default("WAITING")
  progress   Int       @default(0)
  result     String?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([queueName])
  @@index([status])
  @@index([jobId])
  @@map("background_jobs")
}

model BusinessContext {
  id          String    @id @default(uuid())
  tenantId    String?
  contextType String
  data        String
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?
  tenants     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([contextType])
  @@index([tenantId])
  @@map("business_contexts")
}

model BusinessRule {
  id             String          @id @default(uuid())
  tenantId       String?
  name           String
  description    String?
  module         String
  isActive       Boolean         @default(true)
  eventTrigger   String
  conditions     String
  actions        String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenants        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ruleExecutions RuleExecution[]

  @@index([isActive])
  @@index([eventTrigger])
  @@index([tenantId])
  @@map("business_rules")
}

model CacheEntry {
  id          String    @id @default(uuid())
  tenantId    String?
  cacheKey    String    @unique
  cacheValue  String
  ttlSeconds  Int?
  expiresAt   DateTime?
  invalidated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenants     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([cacheKey])
  @@index([expiresAt])
  @@index([tenantId])
  @@map("cache_entries")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  quantity  Float
  tenantId  String?
  tenants   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product @relation(fields: [productId], references: [id])
  carts     Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_items")
}

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  subtotal   Float      @default(0)
  taxAmount  Float      @default(0)
  grandTotal Float      @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tenantId   String?
  cartItems  CartItem[]
  tenants    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  image         String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  tenantId      String?
  tenants       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products      Product[]
  subCategories SubCategory[]

  parentId      String?
  parent        Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children      Category[]    @relation("CategoryHierarchy")

  sourceRelationships CategoryRelationship[] @relation("CategorySource")
  targetRelationships CategoryRelationship[] @relation("CategoryTarget")

  @@index([isActive])
  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model CategoryRelationship {
  id               String   @id @default(uuid())
  sourceCategoryId String
  targetCategoryId String
  relationType     String   @default("RELATED") // COMPATIBLE_WITH, FREQUENTLY_BOUGHT_TOGETHER, SUBSUMES
  weight           Float    @default(1.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceCategory Category @relation("CategorySource", fields: [sourceCategoryId], references: [id], onDelete: Cascade)
  targetCategory Category @relation("CategoryTarget", fields: [targetCategoryId], references: [id], onDelete: Cascade)

  @@unique([sourceCategoryId, targetCategoryId, relationType])
  @@index([sourceCategoryId])
  @@index([targetCategoryId])
  @@map("category_relationships")
}

model TenantCapability {
  id             String   @id @default(uuid())
  tenantId       String
  capabilityName String   // e.g., RENTALS, B2B_MARKETPLACE, WORKFORCE, AI_COPILOT
  isActive       Boolean  @default(true)
  settings       String?  // JSON configurations for this specific capability
  grantedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, capabilityName])
  @@index([tenantId])
  @@map("tenant_capabilities")
}

model CheckoutSession {
  id         String   @id @default(uuid())
  customerId String
  cartId     String
  status     String   @default("ACTIVE")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenantId   String?
  tenants    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([customerId])
  @@map("checkout_sessions")
}

model ComplianceRecord {
  id          String   @id @default(uuid())
  tenantId    String?
  reportType  String
  summary     String
  reportData  String
  periodStart DateTime
  periodEnd   DateTime
  generatedBy String?
  createdAt   DateTime @default(now())
  users       User?    @relation(fields: [generatedBy], references: [id])
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([reportType])
  @@index([tenantId])
  @@map("compliance_records")
}

model CopilotConversation {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String
  title     String?
  history   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("copilot_conversations")
}

model CreditAccount {
  id                 String              @id @default(uuid())
  customerId         String              @unique
  creditLimit        Float               @default(0)
  availableCredit    Float               @default(0)
  totalDue           Float               @default(0)
  status             String              @default("ACTIVE")
  duePeriodDays      Int                 @default(30)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  tenantId           String?
  tenants            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers          Customer            @relation(fields: [customerId], references: [id])
  creditTransactions CreditTransaction[]

  @@index([status])
  @@index([customerId])
  @@map("credit_accounts")
}

model CreditTransaction {
  id              String        @id @default(uuid())
  creditAccountId String
  amount          Float
  type            String
  referenceId     String?
  referenceType   String?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenantId        String?
  tenants         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creditAccounts  CreditAccount @relation(fields: [creditAccountId], references: [id])

  @@index([creditAccountId])
  @@map("credit_transactions")
}

model CustomerAddress {
  id          String   @id @default(uuid())
  customerId  String
  type        String   @default("BILLING")
  addressLine String
  city        String
  state       String
  pincode     String
  country     String   @default("India")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String?
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Customer {
  id                String            @id @default(uuid())
  name              String
  companyName       String?
  mobile            String            @unique
  email             String?           @unique
  gstin             String?
  customerType      String            @default("RETAIL")
  creditLimit       Float             @default(0)
  totalDue          Float             @default(0)
  isActive          Boolean           @default(true)
  notes             String?
  razorpayCustomerId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  tenantId          String?
  carts             Cart?
  checkoutSessions  CheckoutSession[]
  creditAccounts    CreditAccount?
  customerAddresses CustomerAddress[]
  tenants           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries        Delivery[]
  invoices          Invoice[]
  ledgerAccounts    LedgerAccount?
  orderAddresses    OrderAddress[]
  orders            Order[]
  payments          Payment[]
  projects          Project[]
  quotations        Quotation[]
  reminders         Reminder[]
  salesOrders       SalesOrder[]
  settlements       Settlement[]

  @@index([isActive])
  @@index([customerType])
  @@index([gstin])
  @@index([mobile])
  @@map("customers")
}

model Delivery {
  id                 String             @id @default(uuid())
  deliveryNumber     String             @unique
  orderId            String
  fulfillmentId      String?
  customerId         String
  warehouseId        String?
  driverId           String?
  vehicleId          String?
  shippingZoneId     String?
  shippingAddress    String?
  shippingCity       String?
  shippingState      String?
  shippingPincode    String?
  deliveryStatus     String             @default("PENDING")
  scheduledDate      DateTime?
  actualDeliveryDate DateTime?
  estimatedDelivery  DateTime?
  deliveryNotes      String?
  failureReason      String?
  returnReason       String?
  deliveryCost       Float              @default(0)
  weight             Float              @default(0)
  createdBy          String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  tenantId           String?
  tenants            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users              User               @relation(fields: [createdBy], references: [id])
  shippingZones      ShippingZone?      @relation(fields: [shippingZoneId], references: [id])
  vehicles           Vehicle?           @relation(fields: [vehicleId], references: [id])
  drivers            Driver?            @relation(fields: [driverId], references: [id])
  warehouses         Warehouse?         @relation(fields: [warehouseId], references: [id])
  customers          Customer           @relation(fields: [customerId], references: [id])
  fulfillments       Fulfillment?       @relation(fields: [fulfillmentId], references: [id])
  orders             Order              @relation(fields: [orderId], references: [id])
  deliveryItems      DeliveryItem[]
  deliveryProofs     DeliveryProof?
  deliveryTimeline   DeliveryTimeline[]
  dispatches         Dispatch[]

  @@index([createdAt])
  @@index([scheduledDate])
  @@index([deliveryStatus])
  @@index([tenantId, deliveryStatus])
  @@index([vehicleId])
  @@index([driverId])
  @@index([customerId])
  @@index([orderId])
  @@index([deliveryNumber])
  @@map("deliveries")
}

model DeliveryItem {
  id           String     @id @default(uuid())
  deliveryId   String
  orderItemId  String?
  productId    String
  productName  String
  sku          String?
  quantity     Float
  deliveredQty Float      @default(0)
  damagedQty   Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tenantId     String?
  tenants      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product    @relation(fields: [productId], references: [id])
  orderItems   OrderItem? @relation(fields: [orderItemId], references: [id])
