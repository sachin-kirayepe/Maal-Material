model EquipmentAsset {
  id          String   @id @default(uuid())
  tenantId    String
  ownerId     String
  name        String
  category    String // HEAVY_MACHINERY, POWER_EQUIPMENT, TOOLS
  model       String
  vinOrSerial String?  @unique
  status      String   @default("AVAILABLE") // AVAILABLE, RENTED, MAINTENANCE, INACTIVE
