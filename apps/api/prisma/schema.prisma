model Unit {
  id           String    @id @default(uuid())
  name         String    @unique
  abbreviation String    @unique
  unitType     String    @default("quantity")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  tenantId     String?
  products     Product[]
  tenants      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([unitType])
  @@map("units")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@index([userId])
  @@map("user_roles")
}

model User {
  id                                    String                  @id @default(uuid())
  email                                 String                  @unique
  password                              String
  firstName                             String?
  lastName                              String?
  isActive                              Boolean                 @default(true)
  createdAt                             DateTime                @default(now())
  updatedAt                             DateTime                @updatedAt
  deletedAt                             DateTime?
  activityLogs                          ActivityLog[]
  auditTrails                           AuditTrail[]
  complianceRecords                     ComplianceRecord[]
  deliveries                            Delivery[]
  deliveryTimeline                      DeliveryTimeline[]
  dispatchesDispatchesPackedByTousers   Dispatch[]              @relation("dispatches_packedByTousers")
  dispatchesDispatchesApprovedByTousers Dispatch[]              @relation("dispatches_approvedByTousers")
  fieldTasks                            FieldTask[]
  goodsReceiptNotes                     GoodsReceiptNote[]
  invoices                              Invoice[]
  ledgerEntries                         LedgerEntry[]
  mobileSessions                        MobileSession[]
  notificationPreferences               NotificationPreference?
  notifications                         Notification[]
  offlineSyncQueues                     OfflineSyncQueue[]
  paymentTransactions                   PaymentTransaction[]
  securityEvents                        SecurityEvent[]
  sessions                              Session[]
  settlements                           Settlement[]
  shopUsers                             ShopUser[]
  stockAdjustments                      StockAdjustment[]
  stockMovements                        StockMovement[]
  stockReservations                     StockReservation[]
  supplierPayments                      SupplierPayment[]
  syncConflicts                         SyncConflict[]
  userRoles                             UserRole[]
  copilotActionIntents                  CopilotActionIntent[]

  @@index([email])
  @@map("users")
}

model Vehicle {
  id                String     @id @default(uuid())
  vehicleNumber     String     @unique
  type              String     @default("TRUCK")
  make              String?
  model             String?
  capacity          Float      @default(0)
  operationalStatus String     @default("ACTIVE")
  isActive          Boolean    @default(true)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  tenantId          String?
  deliveries        Delivery[]
  tenants           Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([operationalStatus])
  @@index([type])
  @@index([vehicleNumber])
  @@map("vehicles")
}

model WarehouseStock {
  id            String    @id @default(uuid())
  warehouseId   String
  productId     String
  quantity      Float     @default(0)
  reservedQty   Float     @default(0)
  damagedQty    Float     @default(0)
  lastCountedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenantId      String?
  tenants       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouses    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
  @@index([warehouseId])
  @@map("warehouse_stocks")
}

model Warehouse {
  id                                                      String               @id @default(uuid())
  name                                                    String               @unique
  code                                                    String               @unique
  address                                                 String?
  city                                                    String?
  state                                                   String?
  pincode                                                 String?
  phone                                                   String?
  latitude                                                Float?
  longitude                                               Float?
  geohash                                                 String?
  serviceRadiusKm                                         Float?               @default(30.0)
  isActive                                                Boolean              @default(true)
  isPrimary                                               Boolean              @default(false)
  createdAt                                               DateTime             @default(now())
  updatedAt                                               DateTime             @updatedAt
  deletedAt                                               DateTime?
  tenantId                                                String?
  deliveries                                              Delivery[]
  dispatches                                              Dispatch[]
  fulfillments                                            Fulfillment[]
  goodsReceiptNotes                                       GoodsReceiptNote[]
  orders                                                  Order[]
  procurementRequests                                     ProcurementRequest[]
  purchaseOrders                                          PurchaseOrder[]
  purchaseReturns                                         PurchaseReturn[]
  siteTransfers                                           SiteTransfer[]
  stockAdjustments                                        StockAdjustment[]
  stockMovementsStockMovementsToWarehouseIdTowarehouses   StockMovement[]      @relation("stock_movements_toWarehouseIdTowarehouses")
  stockMovementsStockMovementsFromWarehouseIdTowarehouses StockMovement[]      @relation("stock_movements_fromWarehouseIdTowarehouses")
  stockReservations                                       StockReservation[]
  warehouseStocks                                         WarehouseStock[]
  tenants                                                 Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([code])
  @@map("warehouses")
}

model WebhookEvent {
  id        String   @id @default(uuid())
  endpoint  String
  event     String
  payload   String
  status    String   @default("PENDING")
  response  String?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhook_events")
}

model WorkforceAttendance {
  id            String              @id @default(uuid())
  workerId      String
  siteId        String
  date          DateTime
  shiftType     String              @default("FULL_DAY")
  hoursWorked   Float               @default(8)
  dailyWage     Float               @default(0)
  wageAmount    Float               @default(0)
  overtimeHours Float               @default(0)
  overtimeRate  Float               @default(0)
  status        String              @default("PRESENT")
  markedBy      String
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenantId      String?
  tenants       Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectSites  ProjectSite         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workers       EcosystemWorkforce  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, siteId, date])
  @@index([status])
  @@index([date])
  @@index([siteId])
  @@index([workerId])
  @@map("worker_attendances")
}

model EcosystemWorkforce {
  id                    String                  @id @default(uuid())
  name                  String
  mobile                String                  @unique
  email                 String?
  skillType             String                  @default("HELPER")
  dailyWage             Float                   @default(0)
  projectId             String?
  contractorName        String?
  aadharNumber          String?
  bankAccount           String?
  ifscCode              String?
  emergencyContact      String?
  latitude              Float?
  longitude             Float?
  geohash               String?
  serviceRadiusKm       Float?                  @default(20.0)
  isActive              Boolean                 @default(true)
  joinDate              DateTime                @default(now())
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  tenantId              String?
  workerAttendances     WorkforceAttendance[]
  workforcePayouts      WorkforcePayout[]
  tenants               Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects              Project?                @relation(fields: [projectId], references: [id])

  @@index([contractorName])
  @@index([isActive])
  @@index([projectId])
  @@index([skillType])
  @@index([mobile])
  @@map("workers")
}

model WorkflowExecution {
  id                  String             @id @default(uuid())
  workflowId          String
  tenantId            String?
  status              String             @default("RUNNING")
  startedAt           DateTime           @default(now())
  completedAt         DateTime?
  logs                String?
  error               String?
  tenants             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationWorkflows AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tenantId])
  @@index([workflowId])
  @@map("workflow_executions")
}

// ==========================================
// ENTERPRISE PROCUREMENT & SUPPLY CHAIN
// ==========================================

model EnterpriseVendor {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  code          String   @unique
  type          String // DISTRIBUTOR, MANUFACTURER, CONTRACTOR, TRANSPORT
  status        String   @default("ACTIVE")
  contactEmail  String?
  paymentTerms  String? // NET30, NET60
  taxIdentifier String?
  region        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scores         VendorScore[]
  purchaseOrders ProcurementPurchaseOrder[]
  quotations     ProcurementQuotation[]

  @@map("vendors")
}

model VendorScore {
  id            String   @id @default(uuid())
  tenantId      String
  vendorId      String
  vendor        EnterpriseVendor   @relation(fields: [vendorId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  deliveryScore Float // 0.0 - 100.0
  qualityScore  Float
  pricingScore  Float
  overallScore  Float
  notes         String?
  createdAt     DateTime @default(now())

  @@map("vendor_scores")
}

model PurchaseRequisition {
  id             String                     @id @default(uuid())
  tenantId       String
  prNumber       String                     @unique
  department     String
  requestedBy    String
  status         String                     @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED, ORDERED
  priority       String                     @default("NORMAL")
  justification  String?
  estimatedCost  Float?
  currency       String                     @default("USD")
  requiredDate   DateTime?
  items          String // Store as JSON string since sqlite doesn't natively support JSON arrays elegantly without workarounds in some versions, or I'll just use String
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  rfqs           Rfq[]
  purchaseOrders ProcurementPurchaseOrder[]

  @@map("purchase_requisitions")
}

model Rfq {
  id                    String                 @id @default(uuid())
  tenantId              String
  rfqNumber             String                 @unique
  purchaseRequisitionId String?
  purchaseRequisition   PurchaseRequisition?   @relation(fields: [purchaseRequisitionId], references: [id])
  status                String                 @default("OPEN") // OPEN, CLOSED, AWARDED
  biddingDeadline       DateTime
  items                 String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  quotations            ProcurementQuotation[]

  @@map("rfqs")
}

model ProcurementQuotation {
  id          String   @id @default(uuid())
  tenantId    String
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id])
  vendorId    String
  vendor      EnterpriseVendor   @relation(fields: [vendorId], references: [id])
  totalAmount Float
  currency    String   @default("USD")
  validUntil  DateTime
  status      String   @default("SUBMITTED") // SUBMITTED, REJECTED, ACCEPTED
  terms       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("procurement_quotations")
}

model ProcurementPurchaseOrder {
  id                    String                    @id @default(uuid())
  tenantId              String
  poNumber              String                    @unique
  vendorId              String
  vendor                EnterpriseVendor          @relation(fields: [vendorId], references: [id])
  purchaseRequisitionId String?
  purchaseRequisition   PurchaseRequisition?      @relation(fields: [purchaseRequisitionId], references: [id])
  status                String                    @default("ISSUED") // ISSUED, PARTIAL, FULFILLED, CANCELLED
  totalAmount           Float
  currency              String                    @default("USD")
  items                 String
  expectedDeliveryDate  DateTime?
  landedCostEstimate    Float?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  goodsReceipts         ProcurementGoodsReceipt[]

  @@map("procurement_purchase_orders")
}

model ProcurementGoodsReceipt {
  id              String                   @id @default(uuid())
  tenantId        String
  grnNumber       String                   @unique
  purchaseOrderId String
  purchaseOrder   ProcurementPurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedBy      String
  warehouseId     String?
  status          String                   @default("RECEIVED") // RECEIVED, INSPECTED, REJECTED
  items           String
  receiptDate     DateTime                 @default(now())
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@map("procurement_goods_receipts")
}

model ProcurementWorkflow {
  id            String   @id @default(uuid())
  tenantId      String
  referenceId   String // PR ID or PO ID
  referenceType String // PR or PO
  stage         Int      @default(1)
  requiredRole  String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy    String?
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("procurement_workflows")
}

model ProcurementAuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  entityId   String
  entityType String // PR, PO, RFQ, GRN
  action     String
  actor      String
  metadata   String?
  timestamp  DateTime @default(now())

  @@map("procurement_audit_logs")
}

model SupplyTransfer {
  id                String    @id @default(uuid())
  tenantId          String
  transferNumber    String    @unique
  sourceWarehouseId String
  targetWarehouseId String
  status            String    @default("PENDING") // PENDING, IN_TRANSIT, RECEIVED, CANCELLED
  items             String
  shippedDate       DateTime?
  receivedDate      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("supply_transfers")
}

// ====================================================
// INDUSTRIAL CONSTRUCTION EXECUTION & SITE OPERATIONS
// ====================================================

model CommerceProject {
  id                   String    @id @default(uuid())
  tenantId             String?
  name                 String
  code                 String    @unique
  description          String?
  status               String    @default("PLANNING") // PLANNING, ACTIVE, ON_HOLD, COMPLETED
  budget               Float     @default(0.0)
  currency             String    @default("USD")
  startDate            DateTime
  estimatedEndDate     DateTime
  actualEndDate        DateTime?
  location             String?
  managerId            String?
  costToDate           Float     @default(0.0)
  profitability        Float     @default(0.0)
  completionPercentage Float     @default(0.0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  phases         CommercePhase[]
  milestones     CommerceMilestone[]
  boqItems       FieldBOQItem[]
  siteActivities FieldActivity[]
  issues         CommerceIssue[]

  @@index([tenantId])
  @@index([status])
  @@map("construction_projects")
}

model CommercePhase {
  id          String    @id @default(uuid())
  tenantId    String?
  projectId   String
  name        String
  description String?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project    CommerceProject     @relation(fields: [projectId], references: [id])
  milestones CommerceMilestone[]

  @@index([projectId])
  @@map("construction_phases")
}

model CommerceMilestone {
  id            String    @id @default(uuid())
  tenantId      String?
  projectId     String
  phaseId       String?
  name          String
  description   String?
  dueDate       DateTime
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  paymentAmount Float     @default(0.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

