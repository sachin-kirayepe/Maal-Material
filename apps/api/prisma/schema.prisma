model ExperienceDashboard {
  id          String   @id @default(uuid())
  tenantId    String?  // Null means system-wide default template
  name        String   // e.g. "Supplier Default Dashboard", "Workforce Mobile Dashboard"
  roleTarget  String?  // The primary role this dashboard targets (e.g. "SUPPLIER")
  isDefault   Boolean  @default(false)
  layoutType  String   @default("GRID") // GRID, LIST, STACK
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  placements  DashboardWidgetPlacement[]
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([roleTarget])
  @@map("experience_dashboards")
}

model DashboardWidget {
  id             String   @id @default(uuid())
  widgetCode     String   @unique // e.g. "RENTAL_ACTIVE_BOOKINGS", "SUPPLIER_PENDING_INVOICES"
  name           String
  description    String?
  componentName  String   // Frontend React component registry name
  defaultWidth   Int      @default(12) // 1-12 grid system
  defaultHeight  Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  placements     DashboardWidgetPlacement[]
  requiredCaps   WidgetCapabilityRequirement[]

  @@index([widgetCode])
  @@map("dashboard_widgets")
}

model DashboardWidgetPlacement {
  id            String   @id @default(uuid())
  dashboardId   String
  widgetId      String
  zone          String   @default("MAIN") // MAIN, SIDEBAR, HEADER, FOOTER
  sortOrder     Int      @default(0)
  width         Int?     // Override default width
  height        Int?     // Override default height
  configJson    String?  // Widget specific JSON config (filters, theme overrides)
  createdAt     DateTime @default(now())

  dashboard     ExperienceDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  widget        DashboardWidget     @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@index([widgetId])
  @@map("dashboard_widget_placements")
}

model WidgetCapabilityRequirement {
  id             String   @id @default(uuid())
  widgetId       String
  capabilityName String   // Refers to TenantCapability.capabilityName

  widget         DashboardWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([widgetId, capabilityName])
  @@map("widget_capability_requirements")
}

